<?php
/**
 * Lift2Event – Konfigurationsreferenz
 *
 * Die eigentliche Konfiguration erfolgt über die Datei ".env" im Projekt-Root
 * (nicht versioniert). Kopiere ".env.example" nach ".env" und passe die Werte an.
 * Diese Datei dient als lesbarer Überblick über alle verfügbaren Einstellungen.
 *
 * Auf einem Produktionsserver:
 *   cp .env.example .env
 *   php artisan key:generate
 *   php artisan migrate --force
 */

return [

    // -------------------------------------------------------------------------
    // Anwendung
    // -------------------------------------------------------------------------
    'APP_NAME'     => 'Lift2Event',
    'APP_ENV'      => 'production',   // local | production
    'APP_DEBUG'    => false,
    'APP_URL'      => 'https://deine-domain.de',
    'APP_LOCALE'   => 'de',           // Standardsprache: de | en | fr | zh

    // -------------------------------------------------------------------------
    // Datenbank (MariaDB oder PostgreSQL)
    // -------------------------------------------------------------------------
    'DB_CONNECTION' => 'mysql',       // mysql | pgsql
    'DB_HOST'       => '127.0.0.1',
    'DB_PORT'       => 3306,
    'DB_DATABASE'   => 'lift2event',
    'DB_USERNAME'   => 'lift2event',
    'DB_PASSWORD'   => 'geheimes_passwort',

    // -------------------------------------------------------------------------
    // E-Mail / SMTP  (für Passwort-Reset und Mitfahrt-Bestätigungsmails)
    // -------------------------------------------------------------------------
    'MAIL_MAILER'       => 'smtp',
    'MAIL_HOST'         => 'smtp.example.com',
    'MAIL_PORT'         => 587,
    'MAIL_USERNAME'     => 'user@example.com',
    'MAIL_PASSWORD'     => 'smtp_passwort',
    'MAIL_ENCRYPTION'   => 'tls',
    'MAIL_FROM_ADDRESS' => 'noreply@deine-domain.de',
    'MAIL_FROM_NAME'    => 'Lift2Event',

    // -------------------------------------------------------------------------
    // Geocoding  (Nominatim-kompatibel, austauschbar z.B. gegen Geoapify)
    // -------------------------------------------------------------------------
    'NOMINATIM_URL'        => 'https://nominatim.openstreetmap.org',
    'NOMINATIM_USER_AGENT' => 'Lift2Event/1.0 deine-email@example.com',

    // -------------------------------------------------------------------------
    // Kartenkacheln  (OpenStreetMap oder kommerzieller Anbieter)
    // -------------------------------------------------------------------------
    'OSM_TILE_URL' => 'https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png',

];
