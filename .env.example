APP_NAME=Lift2Event
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
APP_LOCALE=de
APP_FALLBACK_LOCALE=de

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Database (MariaDB or PostgreSQL)
DB_CONNECTION=mysql
DB_HOST=db
DB_PORT=3306
DB_DATABASE=lift2event
DB_USERNAME=lift2event
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# Mail / SMTP (for password-reset and ride confirmation emails)
MAIL_MAILER=smtp
MAIL_HOST=127.0.0.1
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Geocoding – Nominatim-compatible endpoint (replaceable with e.g. Geoapify)
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="Lift2Event/1.0 contact@example.com"

# OpenStreetMap tile URL template (replaceable with a commercial provider)
OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

VITE_APP_NAME="${APP_NAME}"
VITE_NOMINATIM_URL="${NOMINATIM_URL}"
VITE_OSM_TILE_URL="${OSM_TILE_URL}"
