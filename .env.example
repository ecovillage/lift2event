# Lift2Event – Konfigurationsvorlage
# Kopiere diese Datei nach ".env" und passe die Werte an.
# ".env" wird nicht versioniert. Diese Datei schon.

APP_NAME=Lift2Event
APP_ENV=local                  # local | production
APP_KEY=                       # wird per "php artisan key:generate" befüllt
APP_DEBUG=true                 # in Produktion auf false setzen
APP_URL=http://localhost:8080
APP_LOCALE=de                  # Standardsprache: de | en | fr | zh
APP_FALLBACK_LOCALE=de

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug                # in Produktion: warning oder error

# ------------------------------------------------------------------------------
# Datenbank – MariaDB oder PostgreSQL werden unterstützt
# ------------------------------------------------------------------------------
DB_CONNECTION=mysql            # mysql (MariaDB) | pgsql (PostgreSQL)
DB_HOST=db                     # im Docker-Setup: "db"; auf dem Server: 127.0.0.1
DB_PORT=3306
DB_DATABASE=lift2event
DB_USERNAME=lift2event
DB_PASSWORD=secret
DB_ROOT_PASSWORD=secret        # nur für Docker-Setup benötigt

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ------------------------------------------------------------------------------
# E-Mail / SMTP
# Wird verwendet für: Passwort-Reset, Mitfahrt-Bestätigungsmail mit Edit-Link
# ------------------------------------------------------------------------------
MAIL_MAILER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="noreply@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# ------------------------------------------------------------------------------
# Geocoding – Nominatim-kompatibler Endpunkt
# Kann gegen einen kommerziellen Dienst (z.B. Geoapify, LocationIQ) ausgetauscht
# werden, solange er die Nominatim-API nachbildet.
# ------------------------------------------------------------------------------
NOMINATIM_URL=https://nominatim.openstreetmap.org
NOMINATIM_USER_AGENT="Lift2Event/1.0 deine-email@example.com"

# ------------------------------------------------------------------------------
# Kartenkacheln (OpenStreetMap oder kompatibler kommerzieller Anbieter)
# ------------------------------------------------------------------------------
OSM_TILE_URL=https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png

# Vite übergibt diese Werte an das Vue-Frontend (VITE_-Präfix erforderlich)
VITE_APP_NAME="${APP_NAME}"
VITE_NOMINATIM_URL="${NOMINATIM_URL}"
VITE_OSM_TILE_URL="${OSM_TILE_URL}"
